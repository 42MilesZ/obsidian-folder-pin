{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": false,
    "inlineSources": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "main.ts"
  ]
}
